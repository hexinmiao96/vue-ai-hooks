{
  "name": "vue-ai-hooks",
  "version": "0.2.0-alpha.1",
  "description": "Vue 3 Composable library for building AI-powered applications. useChat, useCompletion, useEmbedding — multi-provider, streaming-first, fully typed.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.build.json && vite build",
    "typecheck:all": "vue-tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc -p tsconfig.build.json",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"tests/**/*.ts\"",
    "prepublishOnly": "pnpm build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "ai",
    "llm",
    "openai",
    "chatgpt",
    "claude",
    "hooks",
    "streaming",
    "gpt",
    "embedding"
  ],
  "license": "MIT",
  "author": "hexinmiao96",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexinmiao96/vue-ai-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/hexinmiao96/vue-ai-hooks/issues"
  },
  "homepage": "https://github.com/hexinmiao96/vue-ai-hooks#readme",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.4",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "happy-dom": "^14.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.4.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
