{
  "name": "vue-ai-hooks",
  "version": "1.0.0",
  "description": "Vue 3 Composable library for building AI-powered applications, with optional React chat, completion, object, image, video, prompt suggestion, and agent entries. useChat, useCompletion, useEmbedding, useImage, useVideo, useSpeech, useTranscription, useRerank, useObject, useAgentContext, useAgentCapabilities, useAgentRun, usePromptSuggestions — multi-provider, streaming-first, fully typed.",
