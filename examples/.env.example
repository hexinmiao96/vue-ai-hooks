# Runtime provider switch used by example apps.
# Supported values: openai, openrouter, gemini, proxy.
# If omitted, examples default to openai.
VITE_EXAMPLE_PROVIDER=openrouter
# Chat also supports local-tools for the deterministic tool approval demo.
VITE_CHAT_PROVIDER=local-tools

# OpenAI-compatible provider keys
VITE_OPENAI_KEY=sk-...
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter provider keys and metadata (optional)
VITE_OPENROUTER_API_KEY=sk-or-v1-...
VITE_OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
VITE_OPENROUTER_SITE_URL=https://your-app.example.com
VITE_OPENROUTER_APP_NAME=Vue AI Hooks

# Gemini provider keys (optional)
VITE_GEMINI_API_KEY=AIza...
VITE_GEMINI_DEFAULT_MODEL=gemini-3.5-flash
VITE_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Backend proxy provider endpoints (optional).
# For the local proxy example, run `pnpm example:proxy-server` and set:
# VITE_PROXY_BASE_URL=http://127.0.0.1:8787
VITE_PROXY_BASE_URL=
VITE_PROXY_CHAT_URL=/api/ai/chat
VITE_PROXY_COMPLETION_URL=/api/ai/completion
VITE_PROXY_EMBEDDING_URL=/api/ai/embedding
VITE_PROXY_AUTH_TOKEN=
VITE_PROXY_CREDENTIALS=include
